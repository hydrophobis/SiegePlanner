<Window x:Class="R6Planner.Views.GadgetPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:R6Planner.Views"
        Title="Select Gadget" Height="500" Width="400"
        WindowStyle="None" AllowsTransparency="False"
        Background="#0D1117" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <local:GadgetColorConverter x:Key="GadgetColorConverter"/>
        
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#1C2230"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3748"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryRadioBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1F3A5F"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark scrollbar style -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#30363D"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Background" Value="#30363D"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="6" Margin="2"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#58A6FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" 
                                      Style="{StaticResource DarkScrollBar}"
                                      x:Name="PART_VerticalScrollBar"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#010409" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="SELECT GADGET" Foreground="#C9D1D9"
                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="12,0"/>
            <Button Style="{StaticResource DarkBtn}" Content="✕" Width="32"
                    Click="CloseBtn_Click" Padding="0"
                    HorizontalAlignment="Right" Margin="0,0,4,0"
                    Background="#3B1A1A"/>
        </Grid>

        <!-- Search box -->
        <Border Grid.Row="1" Margin="12,12,12,0" Background="#161B22"
                BorderBrush="#21262D" BorderThickness="1" CornerRadius="3">
            <TextBox x:Name="TbSearch" Background="Transparent" Foreground="#C9D1D9"
                     BorderThickness="0" FontFamily="Consolas" FontSize="11"
                     Padding="8,6" CaretBrush="White"
                     TextChanged="TbSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Grid>
                                        <TextBlock Text="🔍 Search gadgets..."
                                                   Foreground="#555F6E"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Padding="8,6"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <!-- Category tabs -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="12,8,12,0">
            <RadioButton x:Name="RbDefender" Content="Defender" GroupName="Category"
                         Style="{StaticResource CategoryRadioBtn}"
                         Checked="Category_Changed"
                         Margin="0,0,4,0"/>
            <RadioButton x:Name="RbAttacker" Content="Attacker" GroupName="Category"
                         Style="{StaticResource CategoryRadioBtn}"
                         Checked="Category_Changed"
                         Margin="2,0"/>
            <RadioButton x:Name="RbUniversal" Content="Universal" GroupName="Category"
                         Style="{StaticResource CategoryRadioBtn}"
                         Checked="Category_Changed"
                         Margin="4,0,0,0"/>
        </UniformGrid>

        <!-- Gadget list -->
        <Border Grid.Row="3" Margin="12,8,12,0" Background="#161B22"
                BorderBrush="#21262D" BorderThickness="1" CornerRadius="3">
            <ListBox x:Name="LbGadgets" Background="Transparent" BorderThickness="0"
                     Foreground="#C9D1D9" FontFamily="Consolas" FontSize="11"
                     SelectionChanged="LbGadgets_SelectionChanged"
                     MouseDoubleClick="LbGadgets_DoubleClick"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="20" Height="20" CornerRadius="3" Margin="0,0,8,0"
                                    Background="{Binding Converter={StaticResource GadgetColorConverter}}"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#8B949E"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1F3A5F"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- Buttons -->
        <UniformGrid Grid.Row="4" Columns="2" Margin="12" Height="32">
            <Button Style="{StaticResource DarkBtn}" Content="Select" Margin="0,0,4,0"
                    Click="SelectBtn_Click" IsDefault="True"/>
            <Button Style="{StaticResource DarkBtn}" Content="Cancel" Margin="4,0,0,0"
                    Click="CloseBtn_Click" IsCancel="True"/>
        </UniformGrid>
    </Grid>
</Window>

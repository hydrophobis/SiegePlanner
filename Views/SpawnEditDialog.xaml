<Window x:Class="R6Planner.Views.SpawnEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spawn Properties" Height="210" Width="320"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="#0D1117" Foreground="#C9D1D9"
        FontFamily="Consolas" FontSize="12"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Letter:" Grid.Row="0" Margin="0,0,0,4"/>
        <TextBox x:Name="TbLetter" Grid.Row="1" Margin="0,0,0,10"
                 Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <TextBlock Text="Spawn label:" Grid.Row="2" Margin="0,0,0,4"/>
        <TextBox x:Name="TbName" Grid.Row="3" Margin="0,0,0,14"
                 Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="0,0,8,0" Click="OkBtn_Click"
                    Background="#1C2230" Foreground="#C9D1D9"/>
            <Button Content="Cancel" Width="70" Click="CancelBtn_Click"
                    Background="#1C2230" Foreground="#C9D1D9"/>
        </StackPanel>
    </Grid>
</Window>

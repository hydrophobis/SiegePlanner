<Window x:Class="R6Planner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:R6Planner.ViewModels"
        xmlns:ctrl="clr-namespace:R6Planner.Controls"
        Title="R6 Siege Planner" Height="800" Width="1280"
        WindowStyle="None" AllowsTransparency="False"
        Background="#0D1117"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Base styles -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"   Value="#1C2230"/>
            <Setter Property="Foreground"   Value="#C9D1D9"/>
            <Setter Property="BorderBrush"  Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3748"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Instant tooltip style matching camera labels -->
        <Style x:Key="InstantTooltip" TargetType="ToolTip">
            <Setter Property="Background" Value="#CC000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter>
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtn" TargetType="ToggleButton">
            <Setter Property="Background"   Value="#161B22"/>
            <Setter Property="Foreground"   Value="#8B949E"/>
            <Setter Property="BorderBrush"  Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontFamily"   Value="Segoe UI Symbol"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1F3A5F"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#58A6FF"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,8,0,3"/>
            <Setter Property="Opacity"     Value="0.7"/>
        </Style>

        <!-- Color swatch button – needs a real template so CornerRadius works -->
        <Style x:Key="ColorSwatchBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>  <!-- title bar -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#010409" MouseLeftButtonDown="TitleBar_Drag">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="◈" Foreground="#E63946" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock Text="R6 SIEGE PLANNER" Foreground="#C9D1D9"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                <TextBlock x:Name="TbMapTitle" Foreground="#58A6FF"
                           FontFamily="Consolas" FontSize="13" Margin="12,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
                <Button Style="{StaticResource DarkBtn}" Content="─" Width="32"
                        Click="MinimizeBtn_Click" Padding="0"/>
                <Button Style="{StaticResource DarkBtn}" Content="□" Width="32"
                        Click="MaximizeBtn_Click" Padding="0"/>
                <Button Style="{StaticResource DarkBtn}" Content="✕" Width="32"
                        Click="CloseBtn_Click" Padding="0"
                        Background="#3B1A1A"/>
            </StackPanel>
        </Grid>

        <!-- ── Main layout ────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>   <!-- left panel -->
                <ColumnDefinition Width="*"/>     <!-- canvas -->
                <ColumnDefinition Width="200"/>   <!-- right panel -->
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: maps + floors ──────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="#0D1117"
                       LastChildFill="True">
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="0,0,1,1" Padding="8,6">
                    <TextBlock Text="MAPS" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <!-- Map list -->
                <ListBox x:Name="LbMaps" DockPanel.Dock="Top" Height="200"
                         Background="#0D1117" BorderThickness="0,0,1,0"
                         BorderBrush="#21262D"
                         Foreground="#C9D1D9" FontFamily="Consolas" FontSize="12"
                         SelectionChanged="LbMaps_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"          Value="10,5"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="Foreground"       Value="#8B949E"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1F3A5F"/>
                                    <Setter Property="Foreground" Value="#58A6FF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#21262D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Floor selector -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="0,1,1,1" Padding="8,6">
                    <TextBlock Text="FLOORS" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" MaxHeight="150"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SpFloors" Background="#0D1117"
                                Margin="0,4"/>
                </ScrollViewer>

                <!-- Visibility toggles -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="0,1,1,1" Padding="8,6">
                    <TextBlock Text="VISIBILITY" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="8,4" Background="#0D1117">
                    <CheckBox x:Name="CbCams" Content="Default Cameras" Margin="0,3"
                              Foreground="#C9D1D9" FontFamily="Consolas" FontSize="11"
                              IsChecked="True" Checked="CbCams_Changed" Unchecked="CbCams_Changed"/>
                    <CheckBox x:Name="CbLoS" Content="Lines of Sight" Margin="0,3"
                              Foreground="#C9D1D9" FontFamily="Consolas" FontSize="11"
                              IsChecked="True" Checked="CbLoS_Changed" Unchecked="CbLoS_Changed"/>
                </StackPanel>

                <!-- Save/Load -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="0,1,1,1" Padding="8,6">
                    <TextBlock Text="FILE" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="8,4" Background="#0D1117">
                    <Button Style="{StaticResource DarkBtn}" Content="💾  Save Plan"
                            Margin="0,3" Click="SaveBtn_Click"/>
                    <Button Style="{StaticResource DarkBtn}" Content="📂  Load Plan"
                            Margin="0,3" Click="LoadBtn_Click"/>
                    <Button Style="{StaticResource DarkBtn}" Content="🗑  Clear All"
                            Margin="0,3" Click="ClearBtn_Click"
                            Background="#3B1A1A"/>
                </StackPanel>

                <Border Background="#0D1117"/>
            </DockPanel>

            <!-- ── Canvas area ────────────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="#010409">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ctrl:MapCanvas x:Name="TheCanvas" Grid.Row="0"
                                Focusable="True"/>

                <!-- Status bar -->
                <Border Grid.Row="1" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TbStatus"
                                   Foreground="#8B949E" FontFamily="Consolas" FontSize="11"
                                   Text="Select a map to begin  |  Ctrl+Z to undo"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Right panel: tools ─────────────────────────────────────── -->
            <DockPanel Grid.Column="2" Background="#0D1117"
                       LastChildFill="True">
                <!-- Tokens -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,0,0,1" Padding="8,6">
                    <TextBlock Text="PLACE" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="6,4">
                    <ToggleButton x:Name="TbAttacker"  Style="{StaticResource ToolBtn}"
                                  Content="⚔ Attacker"  Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceAttacker"/>
                    <ToggleButton x:Name="TbDefender"  Style="{StaticResource ToolBtn}"
                                  Content="🛡 Defender"  Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceDefender"/>
                    <ToggleButton x:Name="TbDrone"     Style="{StaticResource ToolBtn}"
                                  Content="🔵 Drone"     Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceDrone"/>
                    <ToggleButton x:Name="TbBreach"    Style="{StaticResource ToolBtn}"
                                  Content="💥 Breach"    Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceBreach"/>
                    <ToggleButton x:Name="TbObjective" Style="{StaticResource ToolBtn}"
                                  Content="★ Objective"  Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceObjective"/>
                    <ToggleButton x:Name="TbGadget"    Style="{StaticResource ToolBtn}"
                                  Content="🔧 Gadget"    Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceGadget"/>
                </UniformGrid>

                <!-- Gadget selector display -->
                <Border DockPanel.Dock="Top" Margin="6,0,6,4" Background="#161B22" 
                        BorderBrush="#21262D" BorderThickness="1" CornerRadius="3" Padding="4"
                        x:Name="GadgetDisplay" Cursor="Hand"
                        MouseLeftButtonDown="GadgetDisplay_Click">
                    <TextBlock x:Name="TbGadgetName" Text="{Binding ActiveGadgetName}"
                               Foreground="#58A6FF" FontFamily="Consolas" FontSize="10"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </Border>

                <!-- Operator name -->
                <Border DockPanel.Dock="Top" Margin="6,0,6,4">
                    <TextBox x:Name="TbOperator" Background="#161B22" Foreground="#C9D1D9"
                             BorderBrush="#21262D" FontFamily="Consolas" FontSize="11"
                             Padding="4" CaretBrush="White"
                             Text="" TextChanged="TbOperator_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Tag" Value="Operator name…"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Draw -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,1,0,1" Padding="8,6">
                    <TextBlock Text="DRAW" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="6,4">
                    <ToggleButton x:Name="TbSelect"   Style="{StaticResource ToolBtn}"
                                  Content="↖ Select"   Margin="2"
                                  Checked="Tool_Checked" Tag="Select" IsChecked="True"/>
                    <ToggleButton x:Name="TbLoS"      Style="{StaticResource ToolBtn}"
                                  Content="👁 LoS"      Margin="2"
                                  Checked="Tool_Checked" Tag="DrawLoS"/>
                    <ToggleButton x:Name="TbLine"     Style="{StaticResource ToolBtn}"
                                  Content="╱ Line"     Margin="2"
                                  Checked="Tool_Checked" Tag="DrawLine"/>
                    <ToggleButton x:Name="TbArrow"    Style="{StaticResource ToolBtn}"
                                  Content="➔ Arrow"    Margin="2"
                                  Checked="Tool_Checked" Tag="DrawArrow"/>
                    <ToggleButton x:Name="TbRect"     Style="{StaticResource ToolBtn}"
                                  Content="⬜ Rect"    Margin="2"
                                  Checked="Tool_Checked" Tag="DrawRect"/>
                    <ToggleButton x:Name="TbFreehand" Style="{StaticResource ToolBtn}"
                                  Content="✏ Free"     Margin="2"
                                  Checked="Tool_Checked" Tag="DrawFreehand"/>
                    <ToggleButton x:Name="TbText"     Style="{StaticResource ToolBtn}"
                                  Content="T Text"     Margin="2"
                                  Checked="Tool_Checked" Tag="PlaceText"/>
                    <ToggleButton x:Name="TbEraser"   Style="{StaticResource ToolBtn}"
                                  Content="🧹 Eraser"  Margin="2"
                                  Checked="Tool_Checked" Tag="Eraser"/>
                </UniformGrid>

                <!-- Camera -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,1,0,1" Padding="8,6">
                    <TextBlock Text="CAMERA" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <UniformGrid DockPanel.Dock="Top" Columns="1" Margin="6,4">
                    <ToggleButton x:Name="TbCamera"   Style="{StaticResource ToolBtn}"
                                  Content="📹 Edit Cam" Margin="2"
                                  Checked="Tool_Checked" Tag="EditCamera"
                                  Visibility="Collapsed"/>
                    <ToggleButton x:Name="TbSpawn"    Style="{StaticResource ToolBtn}"
                                  Content="⛳ Edit Spawn" Margin="2"
                                  Checked="Tool_Checked" Tag="EditSpawn"
                                  Visibility="Collapsed"/>
                </UniformGrid>

                <!-- Color picker -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,1,0,1" Padding="8,6">
                    <TextBlock Text="COLOR" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <UniformGrid DockPanel.Dock="Top" Columns="5" Margin="6,4">
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#FFD700" Click="ColorBtn_Click" Margin="2" Height="24" Background="#FFD700"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#E63946" Click="ColorBtn_Click" Margin="2" Height="24" Background="#E63946"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#2196F3" Click="ColorBtn_Click" Margin="2" Height="24" Background="#2196F3"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#4CAF50" Click="ColorBtn_Click" Margin="2" Height="24" Background="#4CAF50"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#FF9800" Click="ColorBtn_Click" Margin="2" Height="24" Background="#FF9800"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#9C27B0" Click="ColorBtn_Click" Margin="2" Height="24" Background="#9C27B0"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#00BCD4" Click="ColorBtn_Click" Margin="2" Height="24" Background="#00BCD4"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#FFFFFF" Click="ColorBtn_Click" Margin="2" Height="24" Background="#FFFFFF"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#FF5722" Click="ColorBtn_Click" Margin="2" Height="24" Background="#FF5722"/>
                    <Button Style="{StaticResource ColorSwatchBtn}" Tag="#00FF88" Click="ColorBtn_Click" Margin="2" Height="24" Background="#00FF88"/>
                </UniformGrid>

                <!-- Active color swatch -->
                <Border DockPanel.Dock="Top" Margin="8,2,8,6" Height="20" CornerRadius="3"
                        x:Name="ActiveColorSwatch" Background="#FFD700"/>

                <!-- Legend -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,1,0,1" Padding="8,6">
                    <TextBlock Text="LEGEND" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" Margin="6,4" MaxHeight="160"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="12" Height="12" Fill="#E63946" Margin="0,0,6,0"/>
                            <TextBlock Text="Attacker"  Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="#2196F3" Margin="0,0,6,0"/>
                            <TextBlock Text="Defender"  Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="12" Height="12" Fill="#FF9800" Margin="0,0,6,0"/>
                            <TextBlock Text="Drone"     Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="#9C27B0" Margin="0,0,6,0"/>
                            <TextBlock Text="Breach"    Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="★" Foreground="#4CAF50" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Objective"  Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="12" Height="12" Fill="#FFE032" Margin="0,0,6,0"/>
                            <TextBlock Text="Default Cam" Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="12" Height="12" Fill="#FFE032" Stroke="Black" StrokeThickness="1" Margin="0,0,6,0"/>
                            <TextBlock Text="Spawn" Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Line X1="0" Y1="6" X2="14" Y2="6" Stroke="#00FF88"
                                  StrokeThickness="2" StrokeDashArray="4,2" Margin="0,0,6,0"/>
                            <TextBlock Text="Line of Sight" Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Shortcuts -->
                <Border DockPanel.Dock="Top" Background="#161B22"
                        BorderBrush="#21262D" BorderThickness="1,1,0,1" Padding="8,6">
                    <TextBlock Text="SHORTCUTS" Style="{StaticResource SectionLabel}" Margin="0"/>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="8,4" Background="#0D1117">
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Ctrl+Z  Undo"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Ctrl+Y  Redo"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Ctrl+S  Save"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Esc     Select tool"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="1-8       Tools (1=Select, 8=Eraser)"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="NumPad1-5 Switch floors"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Ctrl+Scroll  Cycle gadgets"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="QWERT   Colors (Yellow-Orange)"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="ASDFG   Colors (Purple-Green)"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="F2      Toggle spawn editor"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="F3      Toggle camera editor"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Del     Clear all"/>
                    <TextBlock Foreground="#555F6E" FontFamily="Consolas" FontSize="10"
                               Text="Right-click token + Delete"/>
                </StackPanel>

                <Border Background="#0D1117"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>

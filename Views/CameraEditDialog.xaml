<Window x:Class="R6Planner.Views.CameraEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Camera" Height="250" Width="300"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="#0D1117" Foreground="#C9D1D9"
        FontFamily="Consolas" FontSize="12">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Name:" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox x:Name="TbName" Grid.Row="1" Margin="0,0,0,10" Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <TextBlock Text="Angle (deg):" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox x:Name="TbAngle" Grid.Row="3" Margin="0,0,0,10" Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <TextBlock Text="FOV Half (deg):" Grid.Row="4" Margin="0,0,0,5"/>
        <TextBox x:Name="TbFov" Grid.Row="5" Margin="0,0,0,10" Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <TextBlock Text="Range (0-1):" Grid.Row="6" Margin="0,0,0,5"/>
        <TextBox x:Name="TbRange" Grid.Row="7" Margin="0,0,0,20" Background="#161B22" Foreground="#C9D1D9" BorderBrush="#30363D"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="60" Margin="0,0,10,0" Click="OkBtn_Click" Background="#1C2230" Foreground="#C9D1D9"/>
            <Button Content="Cancel" Width="60" Click="CancelBtn_Click" Background="#1C2230" Foreground="#C9D1D9"/>
        </StackPanel>
    </Grid>
</Window>